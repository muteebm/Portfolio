{
  "name": "BlogPost",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier"
    },
    "excerpt": {
      "type": "string",
      "description": "Short summary shown in listings"
    },
    "content": {
      "type": "string",
      "description": "Full markdown content"
    },
    "cover_image": {
      "type": "string",
      "description": "Cover image URL"
    },
    "category": {
      "type": "string",
      "enum": [
        "AI & LLMs",
        "Microservices",
        "Backend",
        "Frontend",
        "DevOps",
        "Career",
        "Open Source",
        "Tutorials"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ],
      "default": "draft"
    },
    "read_time": {
      "type": "number",
      "description": "Estimated read time in minutes"
    },
    "views": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title",
    "content"
  ]
}