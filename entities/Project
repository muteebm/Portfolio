{
  "name": "Project",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Project name"
    },
    "description": {
      "type": "string",
      "description": "Short description of the project"
    },
    "long_description": {
      "type": "string",
      "description": "Detailed description of the project"
    },
    "type": {
      "type": "string",
      "enum": [
        "professional",
        "freelance",
        "personal",
        "open_source"
      ],
      "description": "Type of project"
    },
    "tech_stack": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Technologies used"
    },
    "image_url": {
      "type": "string",
      "description": "Cover image URL"
    },
    "live_url": {
      "type": "string",
      "description": "Live demo URL"
    },
    "github_url": {
      "type": "string",
      "description": "GitHub repository URL"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature this project"
    },
    "order": {
      "type": "number",
      "default": 0,
      "description": "Display order"
    }
  },
  "required": [
    "title",
    "description"
  ]
}